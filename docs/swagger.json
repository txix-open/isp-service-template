{
    "swagger": "2.0",
    "info": {
        "description": "Шаблон сервиса",
        "title": "isp-service-template",
        "contact": {},
        "license": {
            "name": "GNU GPL v3.0"
        },
        "version": "1.0.0"
    },
    "host": "localhost:9000",
    "basePath": "/api/isp-service-template",
    "paths": {
        "/object/all": {
            "post": {
                "description": "Возвращает список объектов",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "object"
                ],
                "summary": "Получить все объекты",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Object"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/github_com_txix-open_isp-kit_grpc_apierrors.Error"
                        }
                    }
                }
            }
        },
        "/object/get_by_id": {
            "post": {
                "description": "`errorCode: 800` - если объект не найден",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "object"
                ],
                "summary": "Получить объект по его идентификатору",
                "parameters": [
                    {
                        "description": "Идентификатор объекта",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.ByIdRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.Object"
                        }
                    },
                    "400": {
                        "description": "Объект не найден",
                        "schema": {
                            "$ref": "#/definitions/github_com_txix-open_isp-kit_grpc_apierrors.Error"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/github_com_txix-open_isp-kit_grpc_apierrors.Error"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.ByIdRequest": {
            "type": "object",
            "required": [
                "id"
            ],
            "properties": {
                "id": {
                    "type": "integer"
                }
            }
        },
        "domain.Object": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "maxLength": 32
                }
            }
        },
        "github_com_txix-open_isp-kit_grpc_apierrors.Error": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "errorCode": {
                    "type": "integer"
                },
                "errorMessage": {
                    "type": "string"
                }
            }
        }
    }
}